{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet format:*)",
      "Bash(dotnet --info)",
      "Bash(ng build:*)",
      "Bash(ng test:*)",
      "Bash(ng lint:*)"
    ],
    "ask": [
      "Bash(dotnet add:*)",
      "Bash(dotnet remove:*)",
      "Bash(dotnet ef:*)",
      "Bash(dotnet new:*)",
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm update:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch -d:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)"
    ]
  }
}
