<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- clear verwirft alle geerbten Quellen aus globalen NuGet-Konfigurationen.
       Ohne dies zieht der Build maschinenabhängige Quellen heran und ist nicht reproduzierbar. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
